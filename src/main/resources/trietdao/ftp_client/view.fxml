<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>

<StackPane fx:id="rootStack" prefHeight="760.0" prefWidth="1180.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="trietdao.ftp_client.Controller">
    <children>
        <BorderPane fx:id="mainContent" prefHeight="760.0" prefWidth="1180.0">
            <top>
                <VBox spacing="8.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="10.0" left="12.0" right="12.0" top="12.0" />
                    </padding>
                    <HBox spacing="10.0">
                        <children>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="Host" />
                                    <TextField fx:id="hostField" />
                                </children>
                            </VBox>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="Port" />
                                    <TextField fx:id="portField" />
                                </children>
                            </VBox>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="Username" />
                                    <TextField fx:id="usernameField" />
                                </children>
                            </VBox>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="Password" />
                                    <PasswordField fx:id="passwordField" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                </VBox>
            </top>

            <center>
                <HBox spacing="12.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="0.0" />
                    </padding>
                    <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="remotePathLabel" text="/" />
                                <ListView fx:id="remoteListView" prefHeight="540.0" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0" prefWidth="220.0">
                            <children>
                                <Button fx:id="connectButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onConnectClicked" text="Connect" />
                                <Button fx:id="createDirectoryButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCreateDirectoryClicked" text="Create New Directory" />
                                <Button fx:id="deleteButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onDeleteClicked" text="Delete File" />
                                <Button fx:id="removeDirectoryButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onRemoveDirectoryClicked" text="Remove Directory" />
                                <Button fx:id="uploadButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onUploadClicked" text="Upload" />
                                <Button fx:id="downloadButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onDownloadClicked" text="Download" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </center>

            <bottom>
                <VBox spacing="6.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="0.0" />
                    </padding>
                    <Label text="Console" />
                    <ScrollPane fx:id="consoleScrollPane" fitToWidth="true" prefViewportHeight="150.0" VBox.vgrow="ALWAYS">
                        <content>
                            <TextFlow fx:id="consoleFlow" />
                        </content>
                    </ScrollPane>
                </VBox>
            </bottom>
        </BorderPane>

        <VBox fx:id="busyOverlay" alignment="CENTER" managed="false" mouseTransparent="false" visible="false" style="-fx-background-color: rgba(30,30,30,0.35);">
            <children>
                <ProgressIndicator />
                <Label fx:id="busyMessageLabel" text="Working..." style="-fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 0 0 0;" />
            </children>
        </VBox>
    </children>
</StackPane>
